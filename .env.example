# codex-console Docker / Web UI environment example
# Copy this file to .env and adjust as needed.

# Web UI listen address
WEBUI_HOST=0.0.0.0
WEBUI_PORT=1455

# Web UI access password (required)
WEBUI_ACCESS_PASSWORD=change_me_to_a_strong_password

# Runtime options
DEBUG=0
LOG_LEVEL=info

# Optional app-style variables used by parts of the project
# APP_HOST=0.0.0.0
# APP_PORT=8000
# APP_ACCESS_PASSWORD=change_me_to_a_strong_password
# APP_DATABASE_URL=data/database.db
